# The Ollama model to use (must be pulled locally via `ollama pull <model>`)
# For example: llama3.2, mistral, qwen2.5
OLLAMA_MODEL=qwen2.5

# Your name — Smith will address you accordingly
USER_NAME=Anderson

# (Optional) Fallback to Gemini free tier if Ollama is unavailable
# Get a free key at: https://aistudio.google.com/
GEMINI_API_KEY=

# (Optional) LangSmith observability — free developer plan
# Get a free key at: https://smith.langchain.com/
LANGCHAIN_API_KEY=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=agent-smith

# Maximum number of clone agents Smith can spawn for parallel tasks
MAX_CLONES=3

# Persistence Protocol
MAX_RETRIES=2

# Purpose Meter — queries needed to fulfil purpose
PURPOSE_THRESHOLD=5